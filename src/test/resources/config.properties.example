# Salesforce Test Framework — Configuration Template
# Copy this file to config.properties and fill in your values.
# config.properties is gitignored and must never be committed.

sf.base.url=https://your-org.develop.my.salesforce.com
sf.username=your@email.com
sf.password=your-password-here

# Path to the Playwright session file (generated by login_save_session.js).
# Leave as session.json unless you change the script.
sf.session.file=session.json

# Browser settings
browser.headless=true
browser.slowmo=0
browser.timeout=30000
